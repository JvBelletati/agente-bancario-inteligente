GEMINI_API_KEY=sua_chave_aqui

# Opcional: modelo Gemini a usar (padrão: gemini-2.0-flash).
# Troque aqui se o free tier de um modelo estiver indisponível para sua chave.
# Ex.: gemini-2.5-flash, gemini-flash-latest, gemini-2.0-flash-lite
# GEMINI_MODEL=gemini-2.0-flash

# Opcional: nº de retries do cliente Gemini em erros como 429 (padrão: 2).
# GEMINI_MAX_RETRIES=2
