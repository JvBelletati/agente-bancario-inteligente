# Provedor de LLM: "anthropic" (Claude, padrão) ou "google" (Gemini).
# LLM_PROVIDER=anthropic

# --- Claude / Anthropic (provedor padrão) ---
ANTHROPIC_API_KEY=sua_chave_aqui
# Opcional: modelo Claude (padrão: claude-opus-4-8).
# Para um chatbot multi-agente, um modelo mais rápido/barato costuma ser melhor:
# Ex.: claude-sonnet-5, claude-haiku-4-5
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Gemini / Google (opcional; use com LLM_PROVIDER=google) ---
# GEMINI_API_KEY=sua_chave_aqui
# Opcional: modelo Gemini (padrão: gemini-2.0-flash).
# Ex.: gemini-2.5-flash, gemini-flash-latest, gemini-2.0-flash-lite
# GEMINI_MODEL=gemini-2.0-flash

# Opcional: nº de retries do cliente em erros como 429/cota (padrão: 2).
# LLM_MAX_RETRIES=2
